# ─── Stripe ───────────────────────────────────────────────────────────────
# Required for subscriptions. Get one at: https://dashboard.stripe.com/apikeys
# STRIPE_API_KEY=sk_live_...
# Price ID for your product: https://dashboard.stripe.com/products
STRIPE_PRICE_ID=price_99_month
# Required for webhook signature verification: https://dashboard.stripe.com/webhooks
# STRIPE_WEBHOOK_SECRET=whsec_...

# ─── SendGrid ─────────────────────────────────────────────────────────────
# Required for real email delivery. Get one at: https://app.sendgrid.com/settings/api_keys
# If unset, outreach runs in dry-run mode (logged, not sent).
SENDGRID_API_KEY=
# Verified sender in your SendGrid account.
FROM_EMAIL=noreply@leadgen.app
FROM_NAME=LeadGen Agent

# ─── Database ─────────────────────────────────────────────────────────────
# SQLite for local dev, PostgreSQL in production.
# In docker-compose, this is auto-configured from DB_PASSWORD.
DATABASE_URL=sqlite:///data/leadgen.db

# ─── Auth ─────────────────────────────────────────────────────────────────
# Optional. If set, secures all API endpoints and the dashboard.
# Generate with: openssl rand -hex 32
API_KEY=

# ─── Browser automation ──────────────────────────────────────────────────
# WebSocket URL for Kimi WebBridge Chrome automation.
BROWSER_WS_URL=ws://127.0.0.1:10086/ws
# Browser operation timeouts (seconds)
# BROWSER_TIMEOUT=30
# BROWSER_CONNECT_TIMEOUT=5

# ─── CORS ─────────────────────────────────────────────────────────────────
# Space-separated allowed origins for CORS. Defaults allow local dev.
# In production, set to your domain only:
# CORS_ORIGINS="https://leadgen.yourdomain.com"

# ─── Sentry ──────────────────────────────────────────────────────────────
# Optional. If set, errors are reported to Sentry for monitoring.
# Get one at: https://sentry.io/settings/account/api/keys/
SENTRY_DSN=

# ─── App ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
